# StarLoco Server Configuration
# All sensitive data is stored in secrets/ directory
#
# IMPORTANT: The database user password is read from secrets/starloco_db_password.secret
# during first database initialization. If you change it later, update the user password
# inside MariaDB or recreate the mariadb_data volume.

# Network Config
# Use "127.0.0.1" for localhost-only, "0.0.0.0" for LAN/internet access
BIND_ADDRESS=0.0.0.0

# Game Server Config
GAME_SERVER_IP=127.0.0.1
MARIADB_HOST=mariadb
REDIS_HOST=redis
GAME_SERVER_VERSION=1.39.8
GAME_SERVER_ID=601
GAME_SERVER_KEY=YOUR_GAME_SERVER_KEY
GAME_SERVER_NAME=YOUR_GAME_SERVER_NAME

# Server Rates
RATE_XP=1
RATE_DROP=1
RATE_DROP_THRESHOLD=1
RATE_KAMAS=1
RATE_JOB=1
RATE_FM=1
RATE_HONOR=1
